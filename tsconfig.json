{
  "extends": "./node.json",
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules"],
  "compilerOptions": {
    "jsx": "react",
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "types": ["vitest/globals"],
    "paths": {
      "#config/*": ["./src/config/*"],
      "#controller/*": ["./src/controller/*"],
      "#dao/*": ["./src/dao/*"],
      "#db/*": ["./src/db/*"],
      "#middleware/*": ["./src/middleware/*"],
      "#mocks/*": ["./src/mocks/*"],
      "#modules/*": ["./src/modules/*"],
      "#routes/*": ["./src/routes/*"],
      "#test/*": ["./src/test/*"],
      "#types/*": ["./src/types/*"],
      "#utils/*": ["./src/utils/*"]
    }
  }
}
