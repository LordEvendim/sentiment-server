{
  "name": "server",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "yarn docker:run:dev && tsx watch --clear-screen=false src/index.ts",
    "start": "node ./dist/index.js",
    "start:dev": "tsx ./src/index.ts",
    "build": "tsup src/index.ts --format esm,cjs && (copy \"./.env\" \"./dist\" /y || cp \"./.env\" \"./dist\")",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit && eslint \"src/**/*.ts*\"",
    "lint:verbose": "tsc --noEmit && (TIMING=1 || set TIMING=1) && eslint \"src/**/*.ts*\"",
    "lint:debug": "eslint --debug \"src/**/*.ts*\"",
    "test": "vitest run",
    "test:dev": "vitest",
    "docker:build": "docker compose build",
    "docker:build:dev": "docker compose -f docker-compose.dev.yml build",
    "docker:run:dev": "docker compose -f docker-compose.dev.yml up -d"
  },
  "dependencies": {
    "@google-cloud/aiplatform": "^3.12.0",
    "@google-cloud/vertexai": "^0.4.0",
    "@google/generative-ai": "^0.2.0",
    "@planetscale/database": "^1.16.0",
    "axios": "^1.3.4",
    "bcrypt": "^5.1.0",
    "cache-manager": "^5.2.1",
    "cache-manager-ioredis-yet": "^1.1.0",
    "connect": "^3.7.0",
    "connect-redis": "^7.1.0",
    "cookie": "^0.5.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "cross-fetch": "^3.1.6",
    "date-fns": "^2.30.0",
    "drizzle-orm": "^0.29.3",
    "express": "^4.18.2",
    "express-rate-limit": "^6.7.0",
    "express-session": "^1.17.3",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "mongodb": "^5.6.0",
    "msw": "^1.2.1",
    "nanoid": "3.0.0",
    "path": "^0.12.7",
    "redis": "^4.6.5",
    "simple-statistics": "^7.8.3",
    "winston": "^3.8.2",
    "zod": "^3.21.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/cookie-parser": "^1.4.3",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/express-session": "^1.17.7",
    "@types/node": "^18.14.6",
    "@types/redis": "^4.0.11",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "dotenv": "^16.0.3",
    "dotenv-cli": "^7.3.0",
    "drizzle-kit": "^0.20.14",
    "eslint": "^8.56.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-simple-import-sort": "^12.0.0",
    "nodemon": "^2.0.21",
    "prettier": "^3.1.1",
    "ts-node": "^10.9.1",
    "tsconfig": "*",
    "tsup": "^6.7.0",
    "tsx": "^3.12.5",
    "types": "*",
    "typescript": "^4.9.5",
    "vitest": "^0.31.1"
  }
}
